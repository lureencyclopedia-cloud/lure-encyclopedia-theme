{{!< default}}
<section class="hero hero--feature" aria-labelledby="home-hero-title">
    {{#get "posts" limit="1" filter="featured:true" include="authors"}}
        {{#foreach posts}}
            <article class="hero__card">
                {{#if feature_image}}
                    <figure class="hero__media">
                        <img class="hero__image" src="{{feature_image}}" alt="{{title}}" loading="eager" />
                    </figure>
                {{/if}}
                <div class="hero__content">
                    <p class="hero__eyebrow">Featured entry</p>
                    <h1 id="home-hero-title">{{title}}</h1>
                    {{#if excerpt}}
                        <p class="hero__deck">{{excerpt}}</p>
                    {{/if}}
                    <div class="hero__meta" aria-label="Publication details">
                        <span class="hero__meta-item">By {{primary_author.name}}</span>
                        <span class="hero__meta-item">{{date published_at format="D MMM YYYY"}}</span>
                    </div>
                    <a class="hero__link" href="{{url}}">Read Article</a>
                </div>
            </article>
        {{else}}
            <article class="hero__card">
                <div class="hero__content">
                    <p class="hero__eyebrow">Featured entry</p>
                    <h1 id="home-hero-title">{{@site.title}}</h1>
                    {{#if @site.description}}
                        <p class="hero__deck">{{@site.description}}</p>
                    {{/if}}
                    <div class="hero__meta" aria-label="Publication details">
                        <span class="hero__meta-item">{{@site.title}}</span>
                    </div>
                    <a class="hero__link" href="{{@site.url}}">Read Article</a>
                </div>
            </article>
        {{/foreach}}
    {{else}}
        <article class="hero__card">
            <div class="hero__content">
                <p class="hero__eyebrow">Featured entry</p>
                <h1 id="home-hero-title">{{@site.title}}</h1>
                {{#if @site.description}}
                    <p class="hero__deck">{{@site.description}}</p>
                {{/if}}
                <div class="hero__meta" aria-label="Publication details">
                    <span class="hero__meta-item">{{@site.title}}</span>
                </div>
                <a class="hero__link" href="{{@site.url}}">Read Article</a>
            </div>
        </article>
    {{/get}}
</section>

<section class="content-block" aria-labelledby="latest-entries-title">
    <h2 id="latest-entries-title">Latest entries</h2>
    {{#get "posts" limit="6" order="published_at desc" include="authors"}}
        {{#foreach posts}}
            <article class="card">
                {{#if feature_image}}
                    <a class="card__image-link" href="{{url}}">
                        <img class="card__image" src="{{feature_image}}" alt="{{title}}" />
                    </a>
                {{/if}}
                <div class="card__content">
                    <p class="card__meta">{{primary_author.name}} • {{date published_at format="D MMM YYYY"}}</p>
                    <h3><a href="{{url}}">{{title}}</a></h3>
                    <p class="card__excerpt">{{excerpt}}</p>
                </div>
            </article>
        {{else}}
            <p>No posts yet.</p>
        {{/foreach}}
    {{/get}}
</section>
