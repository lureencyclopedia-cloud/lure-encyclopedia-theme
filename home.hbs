<section class="hero">
    <h1>{{@site.title}}</h1>
    {{#if @site.description}}
        <p class="hero-description">{{@site.description}}</p>
    {{/if}}
</section>

<section class="content-block">
    <h2>Latest entries</h2>
    {{#get "posts" limit="6" order="published_at desc" include="authors"}}
        {{#foreach posts}}
            <article class="card">
                <h3><a href="{{url}}">{{title}}</a></h3>
                <p>{{excerpt}}</p>
            </article>
        {{else}}
            <p>No posts yet.</p>
        {{/foreach}}
    {{/get}}
</section>
