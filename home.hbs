{{!< default}}
<section class="hero hero--feature" aria-labelledby="home-hero-title">
    <div class="hero__shell">
        {{#get "posts" limit="1" filter="featured:true" include="authors"}}
            {{#foreach posts}}
                <article class="hero__card">
                    <div class="hero__content">
                        <p class="hero__eyebrow">FEATURED ENTRY</p>
                        <h1 id="home-hero-title">
                            <span class="hero__headline-line">The history</span>
                            <span class="hero__headline-line hero__headline-line--small">lives in</span>
                            <span class="hero__headline-line">the lures.</span>
                        </h1>
                        <p class="hero__deck">Documenting the history, evolution, and practical use of fishing lures.</p>
                    </div>
                    <div class="hero__media">
                        <img class="hero__image" src="{{asset 'images/hero-placeholder.png'}}" alt="" loading="eager" />
                    </div>
                </article>
            {{else}}
                <article class="hero__card">
                    <div class="hero__content">
                        <p class="hero__eyebrow">FEATURED ENTRY</p>
                        <h1 id="home-hero-title">
                            <span class="hero__headline-line">The history</span>
                            <span class="hero__headline-line hero__headline-line--small">lives in</span>
                            <span class="hero__headline-line">the lures.</span>
                        </h1>
                        <p class="hero__deck">Documenting the history, evolution, and practical use of fishing lures.</p>
                    </div>
                    <div class="hero__media">
                        <img class="hero__image" src="{{asset 'images/hero-placeholder.png'}}" alt="" loading="eager" />
                    </div>
                </article>
            {{/foreach}}
        {{else}}
            <article class="hero__card">
                <div class="hero__content">
                    <p class="hero__eyebrow">FEATURED ENTRY</p>
                    <h1 id="home-hero-title">
                        <span class="hero__headline-line">The history</span>
                        <span class="hero__headline-line hero__headline-line--small">lives in</span>
                        <span class="hero__headline-line">the lures</span>
                    </h1>
                    <p class="hero__deck">Documenting the history, evolution, and practical use of fishing lures.</p>
                </div>
                <div class="hero__media">
                    <img class="hero__image" src="{{asset 'images/hero-placeholder.png'}}" alt="" loading="eager" />
                </div>
            </article>
        {{/get}}
    </div>
</section>

<section class="content-block" aria-labelledby="latest-entries-title">
    <h2 id="latest-entries-title">Latest entries</h2>
    {{#get "posts" limit="6" order="published_at desc" include="authors"}}
        {{#foreach posts}}
            <article class="card">
                {{#if feature_image}}
                    <a class="card__image-link" href="{{url}}">
                        <img class="card__image" src="{{feature_image}}" alt="{{title}}" />
                    </a>
                {{/if}}
                <div class="card__content">
                    <p class="card__meta">{{primary_author.name}} • {{date published_at format="D MMM YYYY"}}</p>
                    <h3><a href="{{url}}">{{title}}</a></h3>
                    <p class="card__excerpt">{{excerpt}}</p>
                </div>
            </article>
        {{else}}
            <p>No posts yet.</p>
        {{/foreach}}
    {{/get}}
</section>

<section class="featured-story">
    <div class="featured-story__container">
        {{#get "posts" filter="featured:true" limit="1"}}
            {{#foreach posts}}
            <div class="featured-story__content">
                <p class="featured-story__eyebrow">FEATURED STORY</p>
                <h2 class="featured-story__title">{{title}}</h2>
                {{#if custom_excerpt}}<p class="featured-story__subtitle">{{custom_excerpt}}</p>{{/if}}
                <p class="featured-story__excerpt">{{excerpt words="40"}}</p>
                <a class="featured-story__link" href="{{url}}">READ THE STORY →</a>
            </div>
            <div class="featured-story__media">
                {{#if feature_image}}<img class="featured-story__image" src="{{feature_image}}" alt="{{title}}">{{/if}}
            </div>
            {{/foreach}}
        {{/get}}
    </div>
</section>

<section class="latest">
    <div class="latest__container">
        <div class="latest__header">
            <p class="latest__eyebrow">LATEST ARTICLES</p>
            <a class="latest__viewall" href="{{@site.url}}/browse/">VIEW ALL ARTICLES →</a>
        </div>
        <div class="latest__grid">
            {{#get "posts" limit="4" order="published_at desc"}}
                {{#foreach posts}}
                <article class="latest__card">
                    <a class="latest__link" href="{{url}}">
                        {{#if feature_image}}
                        <div class="latest__media"><img class="latest__image" src="{{feature_image}}" alt="{{title}}"></div>
                        {{/if}}
                        {{#primary_tag}}<p class="latest__category">{{name}}</p>{{/primary_tag}}
                        <h3 class="latest__title">{{title}}</h3>
                        <p class="latest__date">{{date format="MMMM D, YYYY"}}</p>
                    </a>
                </article>
                {{/foreach}}
            {{/get}}
        </div>
    </div>
</section>

<section class="newsletter">
    <div class="newsletter__container">
        <div class="newsletter__info">
            <p class="newsletter__label">STAY IN THE LOOP</p>
            <p class="newsletter__description">New articles, lure history, and updates delivered straight to your inbox.</p>
        </div>
        <form class="newsletter__form" data-members-form>
            <input class="newsletter__input" type="email" data-members-email placeholder="Your email address" required>
            <button class="newsletter__button" type="submit">SUBSCRIBE</button>
        </form>
    </div>
</section>
