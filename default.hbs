<!doctype html>
<html lang="{{@site.lang}}">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{meta_title}}</title>
    <meta name="description" content="{{meta_description}}" />
    <link rel="stylesheet" href="{{asset 'css/variables.css'}}" />
    <link rel="stylesheet" href="{{asset 'css/base.css'}}" />
    <link rel="stylesheet" href="{{asset 'css/typography.css'}}" />
    <link rel="stylesheet" href="{{asset 'css/layout.css'}}" />
    <link rel="stylesheet" href="{{asset 'css/utilities.css'}}" />
    {{ghost_head}}
</head>
<body class="{{body_class}}">
    <a class="skip-link" href="#main-content">Skip to content</a>

    <div class="site-shell">
        <header class="site-header" role="banner">
            <div class="container site-header__inner">
                <div class="site-header__branding">
                    <a class="site-brand" href="{{@site.url}}" rel="home" aria-label="{{@site.title}}">
                        <span class="site-brand__mark" aria-hidden="true">
                            <img class="site-brand__logo" src="{{asset 'images/branding/logo-light.svg'}}" alt="" />
                        </span>
                        <span class="site-brand__wordmark">Lure Encyclopedia</span>
                        <span class="site-brand__rule" aria-hidden="true"></span>
                    </a>
                </div>

                <nav class="site-nav" aria-label="Primary navigation">
                    <ul>
                        <li><a href="{{@site.url}}/browse/">Browse</a></li>
                        <li><a href="{{@site.url}}/lure-types/">Lure Types</a></li>
                        <li><a href="{{@site.url}}/about/">About</a></li>
                    </ul>
                </nav>

                <button class="site-header__search" type="button" aria-label="Search">
                    <span class="site-header__search-icon" aria-hidden="true">⌕</span>
                </button>
            </div>
        </header>

        <main id="main-content" class="site-main" tabindex="-1">
            <div class="container site-main__inner">
                {{{body}}}
            </div>
        </main>

        <footer class="footer" role="contentinfo">
            <div class="footer__container">
                <div class="footer__brand">
                    <p class="footer__wordmark">LURE ENCYCLOPEDIA</p>
                    <p class="footer__mission">Lure Encyclopedia is an independent editorial publication dedicated to preserving the history and knowledge of fishing lures for future generations.</p>
                </div>
                <div class="footer__monogram">LE</div>
            </div>
            <div class="footer__bottom">
                <div class="footer__bottom-container">
                    <p class="footer__copyright">© {{date format="YYYY"}} Lure Encyclopedia. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    {{ghost_foot}}
</body>
</html>
